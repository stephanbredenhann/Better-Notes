{
  "expo": {
    "name": "Better Notes",
    "slug": "better-notes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "betternotes",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.betternotes.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Better Notes uses speech recognition so you can blurt by voice.",
        "NSMicrophoneUsageDescription": "Better Notes needs the microphone for voice blurts.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.betternotes.app",
      "adaptiveIcon": {
        "backgroundColor": "#d6f1fc",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#1cb0f6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
